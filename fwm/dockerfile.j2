ARG base_os="{{ base_os }}"
FROM $base_os

ARG CACHEBUST=1
ENV DEBIAN_FRONTEND=noninteractive

# 1. Prepare base structure and OS repositories
RUN rm -rf /var/lib/apt/lists/* && \
    apt-get clean && \
    apt-get update && \
    apt-get dist-upgrade -y && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    gpg \
    procps \
    iproute2 \
    locales \
    tzdata \
    systemd \
    systemd-sysv \
    zstd \
    pciutils

COPY pool/install/ca-{{ server }}.crt /usr/local/share/ca-certificates/

# 2. Register the Migasfree repository and install the client
RUN /usr/sbin/update-ca-certificates --fresh && \
    { \
    echo 'Types: deb'; \
    echo 'URIs: https://{{ server }}/public/{{ project_slug }}/repos/'; \
    echo 'Suites: migasfree'; \
    echo 'Components: PKGS'; \
    echo 'Signed-By: /etc/apt/trusted.gpg.d/{{ server }}.gpg'; \
    echo 'Trusted: yes'; \
    echo ''; \
    } > /etc/apt/sources.list.d/migasfree.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends migasfree-client migasfree-agent

# {% if fqdn_ip %}
RUN echo "{{ fqdn_ip }} {{ server }}" >> /etc/hosts && \
    cat /etc/hosts
# {% endif %}

# =========================================================================
# PREVENTIVE STORAGE CONFIGURATION (INITRAMFS)
# =========================================================================
# We force the inclusion of generic drivers (MODULES=most) before the sync.
# This ensures that when the virtual kernel is installed via Migasfree,
# initramfs is forced to compile SCSI/VirtIO drivers.
# =========================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    udev \
    dbus \
    efibootmgr \
    openssh-server \
    os-prober \
    kmod \
    parted \
    e2fsprogs \
    initramfs-tools

RUN if [ -f /etc/initramfs-tools/initramfs.conf ]; then \
    sed -i 's/MODULES=dep/MODULES=most/g' /etc/initramfs-tools/initramfs.conf; \
    fi

# GRUB bootloader configuration
RUN echo "grub-pc grub-pc/install_devices_empty boolean true" | debconf-set-selections && \
    echo "grub-pc grub-pc/install_devices string " | debconf-set-selections && \
    apt-get install -y --no-install-recommends grub-common grub-pc-bin grub-efi-amd64-bin

# =========================================================================
# 3. Registration and dynamic injection of Migasfree tags
# The {{ tags }} parameter will inject "KERNEL-VIRTUAL" or "KERNEL-PHYSICAL"
# =========================================================================
RUN apt-get install -y --no-install-recommends dmidecode && \
    mv /usr/sbin/dmidecode /usr/sbin/dmidecode.real && \
    echo '#!/bin/bash' > /usr/sbin/dmidecode && \
    echo 'if [[ "$*" == *"system-uuid"* ]]; then echo "{{ system_uuid }}"; elif [[ "$*" == *"-t 0"* ]]; then echo "SMBIOS 3.5.0 present."; else /usr/sbin/dmidecode.real "$@"; fi' >> /usr/sbin/dmidecode && \
    chmod +x /usr/sbin/dmidecode && \
    echo "mci-builder" > /etc/hostname && \
    USER=root migasfree conf --server {{ server }} --project {{ project_name }} --computer-name mci-builder && \
    echo "y" | USER=root migasfree register && \
    USER=root migasfree tags --communicate {{ tags }} && \
    mkdir -p /etc/fonts && touch /etc/fonts/fonts.conf && \
    USER=root migasfree sync && \
    echo "{{ tags }}" > /etc/migasfree.image.tags && \
    apt-get clean && \
    apt-get update

# Localization, users, wired network, and final footprint cleanup
RUN echo "en_US.UTF-8 UTF-8" > /etc/locale.gen && \
    echo "es_ES.UTF-8 UTF-8" >> /etc/locale.gen && \
    locale-gen

RUN echo "LANG=en_US.UTF-8" > /etc/default/locale

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV TZ="{{ timezone }}"

RUN ln -fs /usr/share/zoneinfo/{{ timezone }} /etc/localtime && \
    dpkg-reconfigure -f noninteractive tzdata

RUN install -d -m 0755 /etc/{{ prefix }} && \
    echo '{"server":"{{ server }}","project":"{{ project_slug }}","project_name":"{{ project_name }}","prefix":"{{ prefix }}"}' > /etc/{{ prefix }}/project.json

RUN mkdir -p /etc/systemd/network && \
    echo "[Match]\nName=en* eth*\n\n[Network]\nDHCP=yes" > /etc/systemd/network/20-wired.network

RUN systemctl enable systemd-networkd.service 2>/dev/null; \
    systemctl enable systemd-resolved.service 2>/dev/null; \
    exit 0

RUN adduser --disabled-password --gecos "" {{ user }} && \
    echo "{{ user }}:{{ password }}" | chpasswd && \
    usermod -aG sudo,users {{ user }} && \
    mkdir -p /home/{{ user }} && \
    chown {{ user }}:{{ user }} /home/{{ user }} && \
    chmod 700 /home/{{ user }}

# Clean up Migasfree client configuration, remove local state, restore original dmidecode, and remove Debian sources
RUN USER=root migasfree conf --computer-name "" && \
    rm -rf /var/migasfree-client && \
    mv /usr/sbin/dmidecode.real /usr/sbin/dmidecode && \
    rm -f /etc/apt/sources.list.d/debian.sources

CMD ["/sbin/init"]